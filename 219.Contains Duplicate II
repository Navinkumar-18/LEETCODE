import java.util.*;
class Solution {
    public boolean containsNearbyDuplicate(int[] nums, int k) {
        int left=0;
        int right=0;

        HashSet<Integer> window=new HashSet<>();

        for(right=0;right<nums.length;right++){
            if(window.contains(nums[right])){
                return true;
            }
                window.add(nums[right]);
            if(right-left>=k){
                window.remove(nums[left]);
                left++;
            }
        }
        return false;
    }
}
